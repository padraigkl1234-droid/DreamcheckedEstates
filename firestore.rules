rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Helpers ---------------------------------------------------------
    function isMasterAdmin() {
      return request.auth != null &&
        request.auth.token.email == "padraigkl1234@gmail.com" &&
        request.auth.token.email_verified == true;
    }
    function myProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    // Default to 'member' / '' when the field is absent, so users who predate
    // the rank feature don't error out (a missing key would fail the rule).
    function myRank() {
      return request.auth != null ? myProfile().get('rank', 'member') : 'member';
    }
    function myTeam() {
      return request.auth != null ? myProfile().get('teamId', '') : '';
    }
    // A commander of the given team (chain-of-command oversight).
    function isCommanderOf(teamId) {
      return request.auth != null && myRank() == 'commander' && myTeam() == teamId;
    }

    // ---- Collections -----------------------------------------------------

    // Shared team show board — any signed-in user can read/update shows.
    match /shows/{showId} {
      allow read, write: if request.auth != null;
    }

    // User profiles. Anyone signed in can read the roster; you write only your
    // own doc. Rank is written server-side (Admin SDK), which bypasses rules.
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Shared tasks. Visible to participants and to the person a task is offered
    // to; a team commander (and the master) can oversee every task stamped with
    // their team's id.
    match /tasks/{taskId} {
      function canAccessTask() {
        return request.auth != null && (
          request.auth.uid in resource.data.participants ||
          resource.data.pendingUid == request.auth.uid ||
          isMasterAdmin() ||
          (resource.data.get('teamId', null) != null && isCommanderOf(resource.data.teamId))
        );
      }
      allow read, update, delete: if canAccessTask();
      allow create: if request.auth != null && request.resource.data.ownerUid == request.auth.uid;
    }

    // Authored reports. "team" reports are visible team-wide; "command" reports
    // only to their author, team commanders and the master. Viewers can't file.
    match /reports/{reportId} {
      allow read: if request.auth != null && (
        resource.data.createdBy == request.auth.uid ||
        isMasterAdmin() ||
        (resource.data.teamId == myTeam() &&
          (resource.data.visibility == 'team' || isCommanderOf(resource.data.teamId)))
      );
      allow create: if request.auth != null &&
        request.resource.data.createdBy == request.auth.uid &&
        request.resource.data.teamId == myTeam() &&
        myRank() != 'viewer' &&
        request.resource.data.title is string &&
        request.resource.data.visibility in ['command', 'team'];
      allow update, delete: if request.auth != null && (
        resource.data.createdBy == request.auth.uid ||
        isMasterAdmin() ||
        isCommanderOf(resource.data.teamId)
      );
    }

    // Each user's private compliance/diary state.
    match /jarvisState/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Team-scoped shared forms.
    match /checklistForms/{id} {
      allow read, write: if request.auth != null;
    }
    match /auditForms/{id} {
      allow read, write: if request.auth != null;
    }

    // Team docs are read by members; writes go through the Admin SDK.
    match /teams/{teamId} {
      allow read: if request.auth != null;
    }

    // Estates assignments module.
    match /assignments/{assignmentId} {
      allow read, write: if request.auth != null;
    }

    // Connectivity probe.
    match /test/connection {
      allow read: if true;
    }
  }
}
